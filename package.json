	"main": "webpack.mix.js",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"dev": "set NODE_OPTIONS=--openssl-legacy-provider && npm run development",
		"development": "cross-env NODE_ENV=development webpack --progress --hide-modules --config=node_modules/laravel-mix/setup/webpack.config.js",
		"watch": "cross-env NODE_ENV=development webpack --watch --progress --hide-modules --config=node_modules/laravel-mix/setup/webpack.config.js",
		"watch-poll": "npm run watch -- --watch-poll",
		"hot": "set NODE_OPTIONS=--openssl-legacy-provider && cross-env NODE_ENV=development webpack-dev-server --inline --hot --config=node_modules/laravel-mix/setup/webpack.config.js",
		"prod": "mix --production",
		"test:unit": "node tests/monitoring.unit.js"
	},
